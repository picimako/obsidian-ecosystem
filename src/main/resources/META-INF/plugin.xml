<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<!--suppress PluginXmlPluginLogo -->
<idea-plugin>
    <id>com.picimako.obsidian.ecosystem</id>
    <name>Obsidian Ecosystem</name>
    <vendor url="https://github.com/picimako/obsidian-ecosystem">Tamás Balog</vendor>

    <resource-bundle>messages.ObsidianBundle</resource-bundle>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.jetbrains.plugins.ini4idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <postStartupActivity implementation="com.picimako.obsidian.ProjectStartupActivity"/>

        <lang.substitutor language="TEXT" implementationClass="com.picimako.obsidian.translation.lang.IniLanguageSubstitutor"/>

        <localInspection implementationClass="com.picimako.obsidian.translation.inspection.VariableUsageInspection"
                         id="obsidian.variable.usage" language="Ini"
                         displayName="Translation variables usage" groupPath="Obsidian" groupName="Translations" enabledByDefault="true" level="ERROR" />

        <localInspection
                implementationClass="com.picimako.obsidian.translation.inspection.MissingTranslationInspection"
                id="obsidian.translation.is.original.json" language="Ini"
                displayName="Translation is same as original" groupPath="Obsidian" groupName="Translations" enabledByDefault="true" level="ERROR"/>

        <intentionAction>
            <language>Ini</language>
            <category>Obsidian/Translations</category>
            <className>com.picimako.obsidian.translation.intention.ShowTranslationInOtherLanguageIntention</className>
        </intentionAction>

        <annotator language="Ini" implementationClass="com.picimako.obsidian.translation.annotator.VariableAnnotator"/>
    </extensions>

    <actions>
        <!--suppress PluginXmlI18n -->
        <action id="Obsidian.ToggleIni"
                class="com.picimako.obsidian.translation.lang.IniToggleAction"
                text="Enable INI sytax"
                icon="AllIcons.Debugger.Threads">
            <add-to-group group-id="EditorPopupMenu2" anchor="first"/>
            <add-to-group group-id="EditorContextBarMenu"/>
        </action>
    </actions>
</idea-plugin>
